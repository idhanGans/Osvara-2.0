{
  "name": "osvara-backend",
  "version": "1.0.0",
  "description": "Backend API for Osvara e-commerce platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "keywords": [
    "ecommerce",
    "muslimah",
    "fashion"
  ],
  "author": "Osvara Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "stripe": "^16.0.0",
    "multer": "^1.4.5-lts.1",
    "jsonwebtoken": "^8.5.1",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "@prisma/client": "^5.17.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.5",
    "@types/cors": "^2.8.14",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "prisma": "^5.17.0"
  }
}
